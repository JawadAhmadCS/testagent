OPENAI_API_KEY=your_openai_key
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_SERVICE_ACCOUNT_B64=base64_of_full_service_account_json
# Optional fallback if you don't use GOOGLE_SERVICE_ACCOUNT_B64 / GOOGLE_SERVICE_ACCOUNT_JSON:
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
CHIRP_VOICE_EN=en-US-Chirp3-HD-Kore
# Optional Hebrew Chirp voice. If empty, app uses browser speech synthesis for Hebrew.
CHIRP_VOICE_HE=
PORT=3000
FAST_RESPONSE_MODE=1
FAST_LLM_MODEL=gpt-4o-mini
FAST_MAX_TOKENS=40
